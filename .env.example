# Database (PostgreSQL — used on render branch)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/innovateus

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Admin Auth
# Generate hash with: python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('your-password'))"
ADMIN_PASSWORD_HASH=$2b$12$replace-with-your-hash
EDITOR_PASSWORD_HASH=$2b$12$replace-with-your-hash
JWT_SECRET=replace-with-random-secret-string
# Optional: dedicated salt for hashing IP addresses (analytics). Kept
# separate from JWT_SECRET so rotating one does not affect the other.
# Falls back to JWT_SECRET when unset.
IP_HASH_SALT=

# CORS
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Qualtrics (optional — leave blank to disable)
# Single shared API token. Leave blank to disable Qualtrics entirely.
QUALTRICS_API_TOKEN=
# Production survey (live InnovateUS post-course survey).
# Replace with the real survey ID and datacenter ID from your Qualtrics
# dashboard. Do NOT commit real values to .env.example.
QUALTRICS_PRODUCTION_SURVEY_ID=SV_xxxxxxxxxxxxxxx
QUALTRICS_PRODUCTION_DATACENTER_ID=xxx
# Test survey (used for dev cohorts and smoke checks)
QUALTRICS_TEST_SURVEY_ID=
QUALTRICS_TEST_DATACENTER_ID=
# Default target when a cohort has no explicit qualtrics_target. "production" | "test" | "none".
QUALTRICS_DEFAULT_TARGET=production
# Deprecated single-survey vars (kept for backward-compat — populate QUALTRICS_TEST_* instead)
QUALTRICS_SURVEY_ID=
QUALTRICS_DATACENTER_ID=

# JotForm (optional — leave blank to disable)
JOTFORM_API_KEY=
JOTFORM_FORM_ID=

# OpenAI Models
OPENAI_MODEL_VAGUENESS=gpt-5
OPENAI_MODEL_FOLLOWUPS=gpt-5
OPENAI_MODEL_EXTRACTION=gpt-5
OPENAI_MODEL_CLEANUP=gpt-5
OPENAI_MODEL_PII=gpt-5-mini
OPENAI_MODEL_TRANSCRIPTION=gpt-4o-transcribe

# Environment
ENVIRONMENT=development
