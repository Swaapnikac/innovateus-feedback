# AWS / DynamoDB
AWS_REGION=us-east-1
SURVEYS_TABLE=publicvoice-surveys
SUBMISSIONS_TABLE=publicvoice-submissions

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Admin Auth
# Generate hash with: python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('your-password'))"
ADMIN_PASSWORD_HASH=$2b$12$replace-with-your-hash
EDITOR_PASSWORD_HASH=$2b$12$replace-with-your-hash
JWT_SECRET=replace-with-random-secret-string

# CORS
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Qualtrics (optional — leave blank to disable)
QUALTRICS_API_TOKEN=
QUALTRICS_SURVEY_ID=
QUALTRICS_DATACENTER_ID=

# JotForm (optional — leave blank to disable)
JOTFORM_API_KEY=
JOTFORM_FORM_ID=

# OpenAI Models
OPENAI_MODEL_VAGUENESS=gpt-4.1-nano
OPENAI_MODEL_FOLLOWUPS=gpt-4.1-mini
OPENAI_MODEL_EXTRACTION=gpt-4.1
OPENAI_MODEL_CLEANUP=gpt-4.1-nano
OPENAI_MODEL_TRANSCRIPTION=whisper-1

# Environment
ENVIRONMENT=development
