{
  "version": "1.0",
  "title": "Post-Course Survey",
  "question_groups": [
    { "id": "intro", "label": "Introduction", "randomize": false },
    { "id": "closed_1", "label": "Close-ended questions 1", "randomize": false },
    { "id": "closed_2", "label": "Close-ended questions 2", "randomize": true },
